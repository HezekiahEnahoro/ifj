# ── Vercel Blob ─────────────────────────────────────────────────────────────
# Automatically injected when you connect a Blob store in the Vercel dashboard.
# For local dev: copy this value from Vercel dashboard → Storage → your store → .env.local button
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Admin Panel Auth ────────────────────────────────────────────────────────
# ADMIN_PASSWORD: the password your client types to log in to /admin
ADMIN_PASSWORD=choose-a-strong-password

# ADMIN_SESSION_VALUE: a long random string used to sign the login cookie
# Generate one at: https://generate-secret.vercel.app/64
ADMIN_SESSION_VALUE=some-random-64-character-string-here

# ── AI Bio Extraction ───────────────────────────────────────────────────────
# Used by the "Fill bio from resume" button in /admin/profile
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Contact Form ────────────────────────────────────────────────────────────
# Optional: Resend API key for the contact form email delivery
RESEND_API_KEY=re_...
CONTACT_EMAIL=client@email.com

# ── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-deployed-domain.vercel.app
